# ── Conexión a PostgreSQL ──────────────────────────────────────────────────
# Copiar a .env y completar con credenciales reales.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=inmobiliaria
POSTGRES_USER=inmobiliaria_app
POSTGRES_PASSWORD=changeme

# URL de conexión (formato usado por Prisma / NestJS, §15.3)
DATABASE_URL="postgresql://inmobiliaria_app:changeme@localhost:5432/inmobiliaria?schema=public"

# Pool / SSL (opcional)
# DATABASE_SSL=false
# DATABASE_POOL_MAX=10
