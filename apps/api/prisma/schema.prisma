model companies {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @unique @db.Uuid
  name       String   @db.VarChar(120)
  website    String?
  logo_url   String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ads        ads[]
}

model ads {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id      String    @db.Uuid
  title           String    @db.VarChar(120)
  image_url       String
  link_url        String?
  status          String    @default("active") @db.VarChar(20)
  views_purchased Int       @default(0)
  views_used      Int       @default(0)
  starts_at       DateTime  @default(now()) @db.Timestamptz(6)
  ends_at         DateTime? @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  companies       companies  @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ad_zones        ad_zones[]

  @@index([company_id], map: "idx_ads_company")
  @@index([status, ends_at], map: "idx_ads_serving")
}

model ad_zones {
  ad_id   String @db.Uuid
  zone_id String @db.Uuid
  ads     ads    @relation(fields: [ad_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zones   zones  @relation(fields: [zone_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([ad_id, zone_id])
  @@index([zone_id], map: "idx_ad_zones_zone")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model subscriptions {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String              @db.Uuid
  plan_id                String              @db.Uuid
  status                 subscription_status @default(pending_payment)
  start_date             DateTime?           @db.Timestamptz(6)
  end_date               DateTime?           @db.Timestamptz(6)
  renewed_at             DateTime?           @db.Timestamptz(6)
  auto_renew             Boolean             @default(false)
  property_count         Int?
  renews_subscription_id String?             @db.Uuid
  created_at             DateTime            @default(now()) @db.Timestamptz(6)
  updated_at             DateTime            @default(now()) @db.Timestamptz(6)
  payments               payments[]
  subscription_plans     subscription_plans  @relation(fields: [plan_id], references: [id], onUpdate: NoAction)
  users                  users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  renews                 subscriptions?      @relation("renewal", fields: [renews_subscription_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  renewed_by             subscriptions[]     @relation("renewal")

  @@index([end_date], map: "idx_subscriptions_end")
  @@index([plan_id], map: "idx_subscriptions_plan")
  @@index([status], map: "idx_subscriptions_status")
  @@index([user_id], map: "idx_subscriptions_user")
}

