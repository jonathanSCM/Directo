  last_login_at                                 DateTime?               @db.Timestamptz(6)
  created_at                                    DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                                    DateTime                @default(now()) @db.Timestamptz(6)
  free_trial_used                               Boolean                 @default(false)
  google_id                                     String?                 @unique @db.VarChar(255)
  is_verified                                   Boolean                 @default(false)
  admin_logs                                    admin_logs[]
  favorites                                     favorites[]
  notifications                                 notifications[]
  password_reset_tokens                         password_reset_tokens[]
  payments                                      payments[]
  properties                                    properties[]
  refresh_tokens                                refresh_tokens[]
  subscriptions                                 subscriptions[]
  companies                                     companies?
  support_conversations                         support_conversations[]
  user_roles                                    user_roles[]
  visit_requests_visit_requests_owner_idTousers visit_requests[]        @relation("visit_requests_owner_idTousers")
  visit_requests_visit_requests_user_idTousers  visit_requests[]        @relation("visit_requests_user_idTousers")

  @@index([active_role], map: "idx_users_active_role")
  @@index([status], map: "idx_users_status")
}

