/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model payments {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String         @db.Uuid
  subscription_id       String?        @db.Uuid
  property_id           String?        @db.Uuid
  amount                Decimal        @db.Decimal(12, 2)
  currency              String         @default("USD") @db.VarChar(3)
  method                payment_method
  transaction_reference String?        @db.VarChar(255)
  proof_url             String?
  status                payment_status @default(pending)
  paid_at               DateTime?      @db.Timestamptz(6)
  created_at            DateTime       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime       @default(now()) @db.Timestamptz(6)
  provider              String         @default("manual") @db.VarChar(40)
  metadata              Json           @default("{}")
  subscriptions         subscriptions? @relation(fields: [subscription_id], references: [id], onUpdate: NoAction)
  properties            properties?    @relation(fields: [property_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  users                 users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([method], map: "idx_payments_method")
  @@index([paid_at(sort: Desc)], map: "idx_payments_paid_at")
  @@index([status], map: "idx_payments_status")
  @@index([subscription_id], map: "idx_payments_subscription")
  @@index([property_id], map: "idx_payments_property")
  @@index([user_id], map: "idx_payments_user")
  @@index([transaction_reference], map: "idx_payments_reference")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model properties {
  id                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id              String                   @db.Uuid
  title                 String                   @db.VarChar(200)
  slug                  String                   @unique @db.Citext
  description           String?
  property_type_id      String                   @db.Uuid
  zone_id               String?                  @db.Uuid
  operation             property_operation       @default(sale)
  price                 Decimal                  @db.Decimal(14, 2)
  currency              String                   @default("USD") @db.VarChar(3)
  address               String?                  @db.VarChar(255)
  latitude              Decimal?                 @db.Decimal(10, 7)
  longitude             Decimal?                 @db.Decimal(10, 7)
  bedrooms              Int?                     @db.SmallInt
  bathrooms             Int?                     @db.SmallInt
  area_m2               Decimal?                 @db.Decimal(10, 2)
  status                property_status          @default(draft)
  approval_status       approval_status          @default(pending)
  is_featured           Boolean                  @default(false)
  rejection_reason      String?
  views_count           Int                      @default(0)
  published_at          DateTime?                @db.Timestamptz(6)
  created_at            DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                 @default(now()) @db.Timestamptz(6)
  search_vector         Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('spanish'::regconfig, (COALESCE(title, ''::character varying))::text), 'A'::\"char\") || setweight(to_tsvector('spanish'::regconfig, COALESCE(description, ''::text)), 'B'::\"char\"))"))
  whatsapp              String?                  @db.VarChar(30)
  contact_phone         String?                  @db.VarChar(30)
  favorites             favorites[]
  users                 users                    @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  property_types        property_types           @relation(fields: [property_type_id], references: [id], onUpdate: NoAction)
  zones                 zones?                   @relation(fields: [zone_id], references: [id], onUpdate: NoAction)
  property_amenities    property_amenities[]
  property_images       property_images[]
  support_conversations support_conversations[]
  visit_requests        visit_requests[]
  payments              payments[]

  @@index([approval_status], map: "idx_properties_approval")
  @@index([bedrooms], map: "idx_properties_bedrooms")
  @@index([latitude, longitude], map: "idx_properties_geo")
  @@index([operation], map: "idx_properties_operation")
  @@index([owner_id], map: "idx_properties_owner")
  @@index([price], map: "idx_properties_price")
  @@index([status, approval_status, published_at(sort: Desc)], map: "idx_properties_public_feed")
  @@index([published_at(sort: Desc)], map: "idx_properties_published_at")
  @@index([search_vector], map: "idx_properties_search", type: Gin)
  @@index([status], map: "idx_properties_status")
  @@index([property_type_id], map: "idx_properties_type")
  @@index([zone_id], map: "idx_properties_zone")
}

