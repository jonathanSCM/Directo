model amenities {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String               @db.VarChar(100)
  slug       String               @unique @db.Citext
  icon       String               @default("star") @db.VarChar(50)
  category   String               @default("general") @db.VarChar(50)
  is_active  Boolean              @default(true)
  sort_order Int                  @default(0)
  created_at DateTime             @default(now()) @db.Timestamptz(6)
  property_amenities property_amenities[]

  @@index([is_active], map: "idx_amenities_active")
}

model property_amenities {
  property_id String     @db.Uuid
  amenity_id  String     @db.Uuid
  properties  properties @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  amenities   amenities  @relation(fields: [amenity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([property_id, amenity_id])
  @@index([property_id], map: "idx_property_amenities_property")
  @@index([amenity_id], map: "idx_property_amenities_amenity")
}
